{"noir_version":"1.0.0-beta.22+c57152f91260ecdb9faad4efc20abb14b6d2ece7","hash":"5446967698740100682","abi":{"parameters":[{"name":"root","type":{"kind":"field"},"visibility":"public"},{"name":"nullifier_hash","type":{"kind":"field"},"visibility":"public"},{"name":"recipient","type":{"kind":"field"},"visibility":"public"},{"name":"secret","type":{"kind":"field"},"visibility":"private"},{"name":"index","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"hash_path","type":{"kind":"array","length":4,"type":{"kind":"field"}},"visibility":"private"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"","file_map":{"51":{"source":"\nfn main(\n    root: pub Field,\n    nullifier_hash: pub Field,\n    recipient: pub Field,\n    secret: Field,\n    index: u32,\n    hash_path: [Field; 4]\n) {\n    // 1. Derive the nullifier deterministically: secret * 2026\n    let calculated_nullifier = secret * 2026;\n    assert(calculated_nullifier == nullifier_hash);\n\n    // 2. Derive the commitment leaf: secret * 7\n    let leaf = secret * 7;\n\n    // 3. Reconstruct the Merkle root manually from the path\n    let mut current = leaf;\n    let mut temp_index = index;\n\n    for i in 0..4 {\n        let is_right = (temp_index % 2) == 1;\n        temp_index = temp_index / 2;\n\n        let (left, right) = if is_right {\n            (hash_path[i], current)\n        } else {\n            (current, hash_path[i])\n        };\n\n        // Linear parent hashing: left * 3 + right * 7\n        current = left * 3 + right * 7;\n    }\n\n    assert(current == root);\n\n    // 4. Bind the payout address to the proof\n    let _recipient_binding = recipient;\n}\n","path":"/mnt/d/Mathan Files/Projects/Stellar hack/circuits/src/main.nr","function_locations":[{"start":151,"name":"main"}]}}}